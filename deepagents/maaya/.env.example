# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OpenAI (optional) ─────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000

# ── Model tiers ───────────────────────────────────────────────────────────────
# Override any tier to swap models without touching agent prompts.
# Remove a line to use the built-in default.
MAAYA_MODEL_FAST=anthropic:claude-haiku-4-5-20251001
MAAYA_MODEL_BALANCED=anthropic:claude-sonnet-4-6
MAAYA_MODEL_POWERFUL=anthropic:claude-opus-4-6

# ── Ollama local model offload (optional) ─────────────────────────────────────
# If Ollama is running and OLLAMA_MODEL is set, "fast" tier agents (database,
# devops, tester) are routed to the local model — API cost for boilerplate drops to zero.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=                    # e.g. mistral, codellama, qwen2.5-coder
